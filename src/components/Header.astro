---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="header-fixed">
  <div class="header-wrapper">
    <svg class="header-svg" viewBox="0 0 1440 160" preserveAspectRatio="none">
      <path d="M0,0 L1440,0 L1440,65 L1150,155 L290,155 L0,65 Z" fill="#f0faf8"></path>
    </svg>

    <svg class="header-svg main-path" viewBox="0 0 1440 160" preserveAspectRatio="none">
      <path class="fillpath" d="M0,0 L1440,0 L1440,60 L1140,150 L300,150 L0,60 Z" fill="#1e1f1e"></path>
    </svg>

    <div class="header-content">
      <div class="brand">
        <a href="/" class="header-head-text">marek-prochazka</a>
        <div class="nav-buttons">
          <a class="btn" href="/about">About Me</a>
          <a class="btn" href="/projects">Projects</a>
          <a class="btn" href="/my-path">My Path</a>
        </div>
      </div>
    </div>
  </div>
</header>

<style>
  .header-fixed {
    position: relative;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
  }

  .header-wrapper {
    position: relative;
    width: 100%;
    height: 160px; 
    transition: height 0.3s ease; 
  }

  .header-svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
 
  .main-path {
    z-index: 1;
    transform: translateY(-1px);
  }

  .header-content {
    top: 0;
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    width: 100%;
  }

  .brand {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .header-head-text {
    margin-top: 25px; 
    font-size: 2.5rem;
    color: var(--color-primary);
    text-decoration: none;
  }

  .nav-buttons {
    display: flex;
    flex-direction: row; 
    gap: 30px;
    margin-top: 15px; 
    justify-content: center;
    align-items: center;
  }

  .btn {
    color: var(--color-primary);
    cursor: pointer;
    font-weight: bold;
    padding: 5px 20px;
    transition: 0.3s ease;
    text-decoration: none;
    white-space: nowrap;
  }

  .btn:hover {
    text-shadow: -2px 0 3px var(--color-primary);
  }

  @media (max-width: 768px) {
    .header-wrapper {
      height: 160px;
    }
    .header-head-text {
      font-size: 1.8rem;
      margin-top: 25px;
    }
    .nav-buttons {
      margin-top: 15px;
      gap: 15px;
    }
    .btn {
      padding: 5px 15px;
      font-size: 0.9rem;
    }
  }

  @media (max-width: 480px) {
    .header-wrapper {
      height: 190px; 
    }
    .header-head-text {
      font-size: 1.4rem;
      margin-top: 20px;
    }
    .nav-buttons {
      flex-direction: column; 
      margin-top: 15px;
      gap: 10px; 
    }
    .btn {
      padding: 2px 10px;
      font-size: 0.9rem;
    }
  }
</style>